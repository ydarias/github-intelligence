{
  "name": "@github-intelligence/reporter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others \"npm run dev:server\" \"npm run dev:client\"",
    "lint": "eslint src",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "type-check": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "start": "node dist/server/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@github-intelligence/issues-collector": "*",
    "@github-intelligence/members-collector": "*",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-select": "2.2.6",
    "@tailwindcss/vite": "4.2.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "lucide-react": "1.8.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "recharts": "3.8.1",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "tailwindcss-animate": "1.0.7"
  },
  "devDependencies": {
    "@github-intelligence/tsconfig": "*",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "22.19.17",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.2.1",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite": "8.0.8"
  }
}
